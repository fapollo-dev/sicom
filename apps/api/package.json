    "dev:embedded": "ts-node --transpile-only scripts/dev-embedded.ts"
  },
  "dependencies": {
    "@apollo/shared": "workspace:*",
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "kysely": "^0.27.4",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.16.10",
    "@types/pg": "^8.11.10",
    "embedded-postgres": "18.4.0-beta.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
